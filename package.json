{
  "name": "hna-code",
  "version": "0.3.0",
  "description": "HNA-Code (Humans and Agents Code): run many Claude Code sessions in a configurable grid, glow when a session is waiting on you, resume the whole board after a restart.",
  "main": "src/main/main.js",
  "author": "tyhh00",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder",
    "pack:portable": "electron-builder --win portable",
    "pack:mac": "electron-builder --mac",
    "pack:linux": "electron-builder --linux",
    "pack:dir": "electron-builder --dir",
    "icons": "node build/gen-icons.mjs",
    "test": "node test/hooks.cjs && node test/smoke.mjs && node test/grid.mjs && node test/signal.mjs && node test/glow.mjs && node test/persist.mjs && node test/settings.mjs && node test/multiwindow.mjs && node test/perf.mjs && node test/tabs.mjs && node test/workspaces.mjs && node test/sidebar.mjs && node test/home.mjs && node test/import.mjs && node test/import-manual.mjs && node test/launch-resolve.mjs && node test/accounts.mjs && node test/overflow.mjs && node test/reload.mjs && node test/import-additive.mjs",
    "test:smoke": "node test/smoke.mjs",
    "test:grid": "node test/grid.mjs",
    "test:signal": "node test/signal.mjs",
    "test:glow": "node test/glow.mjs",
    "test:persist": "node test/persist.mjs",
    "test:hooks": "node test/hooks.cjs",
    "test:settings": "node test/settings.mjs",
    "test:multiwindow": "node test/multiwindow.mjs",
    "test:tabs": "node test/tabs.mjs",
    "test:workspaces": "node test/workspaces.mjs",
    "test:sidebar": "node test/sidebar.mjs",
    "test:import": "node test/import.mjs",
    "test:import-manual": "node test/import-manual.mjs",
    "test:home": "node test/home.mjs",
    "test:accounts": "node test/accounts.mjs",
    "test:overflow": "node test/overflow.mjs",
    "test:launch-resolve": "node test/launch-resolve.mjs",
    "test:reload": "node test/reload.mjs",
    "test:import-additive": "node test/import-additive.mjs"
  },
  "dependencies": {
    "@lydell/node-pty": "^1.1.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "playwright": "^1.61.1",
    "png-to-ico": "^3.0.2"
  },
  "build": {
    "appId": "com.tyhh00.hna-code",
    "productName": "HNA-Code",
    "asar": false,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "build/icon.png",
      "build/icon.ico",
      "build/icon.svg",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "HNA-Code"
    },
    "portable": {
      "artifactName": "HNA-Code-${version}-portable.exe"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.developer-tools",
      "identity": null
    },
    "dmg": {
      "artifactName": "HNA-Code-${version}.dmg"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png",
      "category": "Development",
      "artifactName": "HNA-Code-${version}.AppImage"
    }
  }
}
